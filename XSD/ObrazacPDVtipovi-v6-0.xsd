<?xml version="1.0" encoding="UTF-8"?>
<xsd:schema xmlns="http://e-porezna.porezna-uprava.hr/sheme/zahtjevi/ObrazacPDV/v6-0" xmlns:meta="http://e-porezna.porezna-uprava.hr/sheme/Metapodaci/v2-0" xmlns:ispostave="http://e-porezna.porezna-uprava.hr/sheme/temeljno/SifrarnikIspostave/v2-0" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:temeljni="http://e-porezna.porezna-uprava.hr/sheme/TemeljniTipovi/v2-1" targetNamespace="http://e-porezna.porezna-uprava.hr/sheme/zahtjevi/ObrazacPDV/v6-0" elementFormDefault="qualified" version="6.0" id="ObrazacPDVtipovi-v6-0" xml:lang="hr-HR">
	<xsd:annotation>
		<xsd:documentation>XML shema sadrži tipove koji definiraju sadržaj PDV obrasca</xsd:documentation>
	</xsd:annotation>
	<xsd:import namespace="http://e-porezna.porezna-uprava.hr/sheme/TemeljniTipovi/v2-1" schemaLocation="TemeljniTipovi-v2-1.xsd"/>
	<xsd:import namespace="http://e-porezna.porezna-uprava.hr/sheme/Metapodaci/v2-0" schemaLocation="ObrazacPDVmetapodaci-v6-0.xsd"/>
	<xsd:complexType name="sObrazacPDV">
		<xsd:annotation>
			<xsd:documentation>Struktura PDV obrasca</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element ref="meta:Metapodaci"/>
			<xsd:element name="Zaglavlje" type="sZaglavlje">
				<xsd:annotation>
					<xsd:documentation>Zaglavlje obrasca</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Tijelo" type="sTijelo">
				<xsd:annotation>
					<xsd:documentation>Tijelo obrasca</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
		<xsd:attribute name="verzijaSheme" use="required" fixed="6.0"/>
	</xsd:complexType>
	<xsd:complexType name="sZaglavlje">
		<xsd:annotation>
			<xsd:documentation>Zaglavlje obrasca</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Razdoblje" type="sRazdoblje">
				<xsd:annotation>
					<xsd:documentation>Razdoblje za koji se podnosi obrazac</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Obveznik" type="sPoslovniSubjektProsireno">
				<xsd:annotation>
					<xsd:documentation>Podaci o poslovnom subjektu za koji se podnosi obrazac</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ObracunSastavio" type="sObracunSastavio">
				<xsd:annotation>
					<xsd:documentation>Podaci o osobi koja je sastavila obrazac</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Ispostava" type="temeljni:tIspostava">
				<xsd:annotation>
					<xsd:documentation>Ispostava u kojoj se podnosi obrazac</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Napomena" type="tNapomena" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Napomena (maks. 500 znakova)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Zastupnik" type="sZastupnik" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Podaci o poreznom zastupniku</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="sTijelo">
		<xsd:annotation>
			<xsd:documentation>Tijelo obrasca</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Podatak000" type="temeljni:tDecimal15-2"/>
			<xsd:element name="Podatak100" type="temeljni:tDecimal15-2"/>
			<xsd:element name="Podatak110" type="temeljni:tDecimal15-2"/>
			<xsd:element name="Podatak120" type="temeljni:tDecimal15-2"/>
			<xsd:element name="Podatak121" type="temeljni:tDecimal15-2"/>
			<xsd:element name="Podatak122" type="temeljni:tDecimal15-2"/>
			<xsd:element name="Podatak123" type="temeljni:tDecimal15-2"/>
			<xsd:element name="Podatak124" type="temeljni:tDecimal15-2"/>
			<xsd:element name="Podatak130" type="temeljni:tDecimal15-2"/>
			<xsd:element name="Podatak200" type="sIsporuka"/>
			<xsd:element name="Podatak210" type="sIsporuka"/>
			<xsd:element name="Podatak220" type="sIsporuka"/>
			<xsd:element name="Podatak230" type="sIsporuka"/>
			<xsd:element name="Podatak240" type="sIsporuka"/>
			<xsd:element name="Podatak300" type="sIsporuka"/>
			<xsd:element name="Podatak310" type="sIsporuka"/>
			<xsd:element name="Podatak320" type="sIsporuka"/>
			<xsd:element name="Podatak330" type="sIsporuka"/>
			<xsd:element name="Podatak340" type="sIsporuka"/>
			<xsd:element name="Podatak350" type="sIsporukaProsireno"/>
			<xsd:element name="Podatak360" type="sIsporukaProsireno"/>
			<xsd:element name="Podatak370" type="sIsporukaProsireno"/>
			<xsd:element name="Podatak380" type="temeljni:tDecimal15-2"/>
			<xsd:element name="Podatak400" type="temeljni:tDecimal15-2"/>
			<xsd:element name="Podatak500" type="temeljni:tDecimal15-2"/>
			<xsd:element name="Podatak600" type="temeljni:tDecimal15-2"/>
			<xsd:sequence>
				<xsd:element name="Povrat" type="temeljni:tDecimal15-2" minOccurs="0"/>
				<xsd:element name="Predujam" type="temeljni:tDecimal15-2" minOccurs="0"/>
				<xsd:element name="UstupPovrata" type="temeljni:tDecimal15-2" minOccurs="0"/>
			</xsd:sequence>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="sPoslovniSubjekt">
		<xsd:annotation>
			<xsd:documentation>Podaci o poslovnom subjektu</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:choice>
				<xsd:sequence>
					<xsd:element name="Ime" type="temeljni:tOgraniceniZnakovniNizMin2Max128">
						<xsd:annotation>
							<xsd:documentation>Ime ili naziv poslovnog subjekta</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="Prezime" type="temeljni:tOgraniceniZnakovniNizMin2Max128">
						<xsd:annotation>
							<xsd:documentation>Prezime poslovnog subjekta</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
				</xsd:sequence>
				<xsd:element name="Naziv" type="temeljni:tOgraniceniZnakovniNizMin2Max128">
					<xsd:annotation>
						<xsd:documentation>Naziv poslovnog subjekta</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
			</xsd:choice>
			<xsd:element name="OIB" type="temeljni:tOIB">
				<xsd:annotation>
					<xsd:documentation>OIB poslovnog subjekta</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="sAdresa">
		<xsd:annotation>
			<xsd:documentation>Adresa</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Mjesto" type="temeljni:tOgraniceniZnakovniNizMin2Max128">
				<xsd:annotation>
					<xsd:documentation>Naziv mjesta</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Ulica" type="temeljni:tOgraniceniZnakovniNizMin2Max128">
				<xsd:annotation>
					<xsd:documentation>Naziv ulice</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Broj" type="temeljni:tAdresaBroj">
				<xsd:annotation>
					<xsd:documentation>Kućni broj</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="sObracunSastavio">
		<xsd:annotation>
			<xsd:documentation>Podaci o osobi koja je sastavila obrazac</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Ime" type="temeljni:tOgraniceniZnakovniNizMin2Max128">
				<xsd:annotation>
					<xsd:documentation>Ime osobe koja je sastavila obrazac</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Prezime" type="temeljni:tOgraniceniZnakovniNizMin2Max128">
				<xsd:annotation>
					<xsd:documentation>Prezime osobe koja je sastavila obrazac</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Telefon" type="temeljni:tBrojTelefona" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Broj telefona osobe koja je sastavila obracun</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Fax" type="temeljni:tBrojTelefona" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Fax osobe koja je sastavila obracun</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Email" type="temeljni:tEmail" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Mail osobe koja je sastavila obracun</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PoslovniSubjekt" type="sPoslovniSubjekt" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Poslovni subjekt kod kojeg je zaposlena osoba koja je sastavila obrazac (samo ako je različito od poslovnog subjekta za koji se podnosi obrazac)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="sRazdoblje">
		<xsd:annotation>
			<xsd:documentation>Struktura razdoblja (vremenski period)</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="DatumOd" type="xsd:date">
				<xsd:annotation>
					<xsd:documentation>Početni datum</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DatumDo" type="xsd:date">
				<xsd:annotation>
					<xsd:documentation>Završni datum</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="sIsporuka">
		<xsd:annotation>
			<xsd:documentation>Isporuka, sadrži vrijednost i porez</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Vrijednost" type="temeljni:tDecimal15-2"/>
			<xsd:element name="Porez" type="temeljni:tDecimal15-2"/>
		</xsd:sequence>
	</xsd:complexType>
  <xsd:complexType name="sIsporukaProsireno">
    <xsd:annotation>
      <xsd:documentation>Isporuka, sadrži pretporez koji se nemože odbiti, te vrijednost i porez</xsd:documentation>
    </xsd:annotation>
    <xsd:sequence>
      <xsd:element name="PorezNeOdb" type="temeljni:tDecimal15-2"/>
      <xsd:element name="Vrijednost" type="temeljni:tDecimal15-2"/>
      <xsd:element name="Porez" type="temeljni:tDecimal15-2"/>
    </xsd:sequence>
  </xsd:complexType>
	<xsd:simpleType name="tNapomena">
		<xsd:annotation>
			<xsd:documentation>Napomena (maks. 500 znakova)</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:maxLength value="500"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:complexType name="sPoslovniSubjektProsireno">
		<xsd:annotation>
			<xsd:documentation>Podaci o poslovnom subjektu, prošireno s šifrom djelatnosti i adresom</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:choice>
				<xsd:sequence>
					<xsd:element name="Ime" type="temeljni:tOgraniceniZnakovniNizMin2Max128">
						<xsd:annotation>
							<xsd:documentation>Ime ili naziv poslovnog subjekta</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
					<xsd:element name="Prezime" type="temeljni:tOgraniceniZnakovniNizMin2Max128">
						<xsd:annotation>
							<xsd:documentation>Prezime poslovnog subjekta</xsd:documentation>
						</xsd:annotation>
					</xsd:element>
				</xsd:sequence>
				<xsd:element name="Naziv" type="temeljni:tOgraniceniZnakovniNizMin2Max128">
					<xsd:annotation>
						<xsd:documentation>Naziv poslovnog subjekta</xsd:documentation>
					</xsd:annotation>
				</xsd:element>
			</xsd:choice>
			<xsd:element name="OIB" type="temeljni:tOIB">
				<xsd:annotation>
					<xsd:documentation>OIB poslovnog subjekta</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="SifraDjelatnosti" type="temeljni:tSifraDjelatnosti"/>
			<xsd:element name="Adresa" type="sAdresa"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="sZastupnik">
		<xsd:annotation>
			<xsd:documentation>Podaci o poreznom zastupniku</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="Naziv" type="temeljni:tOgraniceniZnakovniNizMin2Max128">
				<xsd:annotation>
					<xsd:documentation>Naziv poreznog zastupnika</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OIB" type="temeljni:tOIB">
				<xsd:annotation>
					<xsd:documentation>OIB poreznog zastupnika</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
</xsd:schema>
